{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      // automatically resolve all files in the src directory with @ prefix
      // e.g. "@components/Foo.astro" -> "src/components/Foo.astro"
      "@/*": ["./src/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  // this also affects the `astro check` command
  "exclude": [
    //
    "./dist",
    "./node_modules"
  ]
}
